#!/usr/bin/env bash
#
# wj — cross-project daily task & time tracker
#
# Source of truth: an append-only TSV event log (one file per day).
# Everything else — status, grid, reports, exports — is derived by replaying it.
#
#   Event row:  timestamp \t task_id \t project \t event \t note
#   Events:     start | pause | resume | complete | defer | log | amend | move | cancel
#
# Layout:
#   ~/.config/wj/cfg                     settings   (INI; override: $WJ_CONFIG)
#   ~/.local/share/wj/YYYY/MM/DD.tsv     event log  (override: $WJ_DATA_DIR)
#   ~/.local/share/wj/exports/           generated on demand
#
set -uo pipefail

WJ_VERSION="0.10.1"

# ---------------------------------------------------------------------------
# Defaults (overridable in the config file)
# ---------------------------------------------------------------------------
# Working-day bounds for the grid/gantt axis. Empty by default here so that
# commenting them out in the config file actually takes effect: an unset bound
# drops the fixed frame and the grid auto-fits the day's real hours. A freshly
# seeded config (see seed_config) writes the friendly 09:00/19:00 explicitly.
shift_start=
shift_end=
slot_minutes=5          # the configurable "jump"
round="down"            # down | nearest   (grid snapping only)
totals="exact"          # exact | slot     (how time totals are summed)
default_project="admin" # used outside a git repo when no --project given
interface="minimal"     # minimal | ui — bare `wj` / `wj ui` launch the wj-tui front-end
auto_pause="off"        # on | off — on start/resume, auto-pause a running task in
                        # the SAME project. off = run them in parallel (default)
accent="141"            # wj-tui border/header color: 256-color code, #hex, or name
layout="balanced"       # wj-tui panel layout: balanced | spotlight | golden | custom (⇧L cycles)
sidebar="left"          # wj-tui sidebar side: left | right
layout_sidebar=""       # custom layout: sidebar width %, e.g. 28 (empty = preset's)
layout_split=""         # custom layout: panel weights focused,hi,lo, e.g. 60,25,15
# wj-tui per-panel title colors (each its own, so the panels stay distinct):
color_projects="39"     # blue
color_tasks="214"       # amber
color_pending="170"     # orchid
color_range="78"        # green
color_day="45"          # cyan
color_timeline="180"    # tan

# ---------------------------------------------------------------------------
# Paths
# ---------------------------------------------------------------------------
CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
WJ_CONFIG="${WJ_CONFIG:-$CONFIG_HOME/wj/cfg}"
WJ_DATA_DIR="${WJ_DATA_DIR:-$DATA_HOME/wj}"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------
die() { printf 'wj: %s\n' "$*" >&2; exit 1; }

# absolute path to this script, so wj-tui can invoke the exact same wj that
# launched it rather than relying on PATH order
self_path() {
    local s=${BASH_SOURCE[0]}
    readlink -f -- "$s" 2>/dev/null || printf '%s' "$s"
}

# every recognised key (a whitelist: the parser ignores anything else, so a
# config file can neither inject arbitrary shell variables nor run commands —
# unlike the old `source`-the-file approach).
_CFG_KEYS=" shift_start shift_end slot_minutes round totals default_project \
auto_pause interface accent layout sidebar layout_sidebar layout_split \
color_projects color_tasks color_pending color_range color_day color_timeline "

seed_config() {
    mkdir -p "$(dirname "$WJ_CONFIG")"
    # NB: shift_start/shift_end use ${var:-default} so a fresh config gets the
    # friendly 09:00–19:00, while a migration preserves whatever was set.
    cat >"$WJ_CONFIG" <<EOF
# wj configuration — INI style: [section] headers, then "key = value".
# '#' starts a comment (a leading-'#' value like a hex color is preserved);
# blank lines are ignored. This file is parsed, not executed.

[tracking]
# Working-day bounds for the grid/gantt axis. Comment these out (or leave them
# empty) to drop the fixed frame: the grid then auto-fits to each day's hours.
shift_start = ${shift_start:-09:00}
shift_end   = ${shift_end:-19:00}
# Grid slot size in minutes (the "jump"), how event times snap, how totals sum.
slot_minutes = $slot_minutes
round        = $round           # down | nearest
totals       = $totals          # exact | slot
# On start/resume, auto-pause another running task in the SAME project.
auto_pause = $auto_pause        # on | off  (override: --parallel / --auto-pause)
# Project used outside a git repo when no --project is given.
default_project = $default_project

[ui]
# Front-end for bare \`wj\`: minimal (today's status table) | ui (the wj-tui app).
interface = $interface
# wj-tui focused-panel border/header color: 256-code (141), #hex, or name.
accent = $accent
# Panel layout: balanced | spotlight | golden | custom. ⇧L cycles, z zooms.
layout = $layout
# Which side the lists column sits on: left | right.
sidebar = $sidebar
# Optional 'custom' layout proportions (then set layout = custom):
layout_sidebar = $layout_sidebar   # sidebar width %, e.g. 28
layout_split   = $layout_split     # focused,hi,lo weights, e.g. 60,25,15

[colors]
# wj-tui per-panel title colors — each its own. Same value formats as accent.
color_projects = $color_projects
color_tasks    = $color_tasks
color_pending  = $color_pending
color_range    = $color_range
color_day      = $color_day
color_timeline = $color_timeline
EOF
}

# trim leading/trailing whitespace from $1
_trim() { local s=$1; s=${s#"${s%%[![:space:]]*}"}; s=${s%"${s##*[![:space:]]}"}; printf '%s' "$s"; }

# parse_config reads an INI-ish file into the recognised config variables. It is
# tolerant of the legacy flat "key=value" format (no [section] headers), so a
# migrated config Just Works. Section headers are organizational only.
parse_config() {
    local file=$1 line key val
    [[ -f $file ]] || return 0
    while IFS= read -r line || [[ -n $line ]]; do
        line=${line%$'\r'}                     # tolerate CRLF
        case "$(_trim "$line")" in
            ''|'#'*|'['*) continue ;;          # blank, comment, or [section]
        esac
        [[ $line == *=* ]] || continue
        key=$(_trim "${line%%=*}")
        [[ $key =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]] || continue   # skip blank/junk keys
        # An inline comment is a '#' followed by whitespace or end-of-line — so a
        # leading-'#' value like a hex color (#9d7cd8) is kept, while "v # note"
        # and an empty "key =  # note" are stripped. Work on the untrimmed value
        # so the space after '=' doesn't masquerade as the pre-comment space.
        val=${line#*=}
        val=${val%%#[[:blank:]]*}              # cut "# comment"  (# then whitespace)
        val=${val%[[:blank:]]#}                # cut a bare trailing " #"
        val=$(_trim "$val")
        case $val in                           # strip one matching pair of surrounding quotes
            \"*\") val=${val#\"}; val=${val%\"} ;;   # (avoid ${v:1:-1}, a bash-4.2 feature)
            \'*\') val=${val#\'}; val=${val%\'} ;;
        esac
        case " $_CFG_KEYS " in *" $key "*) printf -v "$key" '%s' "$val" ;; esac
    done <"$file"
}

# migrate the legacy flat ~/.config/wj/config to the new sectioned cfg, once.
# Triggered only when the target is named "cfg", doesn't yet exist, and a sibling
# "config" does — so a custom $WJ_CONFIG path is never touched. Old values are
# preserved (re-seeded into the new format) and the original kept as config.bak.
migrate_legacy_config() {
    [[ ${WJ_CONFIG##*/} == cfg && ! -e $WJ_CONFIG ]] || return 0
    local legacy="${WJ_CONFIG%/*}/config"
    [[ -f $legacy ]] || return 0
    parse_config "$legacy"          # load the old values into the config vars
    seed_config                     # write them back out in the sectioned format
    mv "$legacy" "$legacy.bak" 2>/dev/null || true
    printf 'wj: migrated %s -> %s (original kept as config.bak)\n' "$legacy" "$WJ_CONFIG" >&2
}

load_config() {
    migrate_legacy_config
    [[ -f $WJ_CONFIG ]] || seed_config
    parse_config "$WJ_CONFIG"
}

# HH:MM -> minutes since midnight
hm_to_min() {
    local hm=$1 h m
    h=${hm%%:*}; m=${hm##*:}
    printf '%d' "$(( 10#$h * 60 + 10#$m ))"
}

# minutes since midnight -> HH:MM
min_to_hm() { printf '%02d:%02d' "$(( $1 / 60 ))" "$(( $1 % 60 ))"; }

# normalise a loose time string to canonical HH:MM on stdout; non-zero on failure.
# accepts: 9  09  930  0930  9:30  9.30  9am  9pm  9:30pm  12am  12pm
normalize_time() {
    local raw h m ap=""
    raw=$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]' | tr -d ' ')
    case $raw in
        *am) ap=am; raw=${raw%am} ;;
        *pm) ap=pm; raw=${raw%pm} ;;
    esac
    raw=${raw//./:}
    if [[ $raw == *:* ]]; then
        h=${raw%%:*}; m=${raw##*:}
    else
        case ${#raw} in
            1|2) h=$raw;        m=0 ;;          # 9 / 09
            3)   h=${raw:0:1};  m=${raw:1:2} ;; # 930  -> 9:30
            4)   h=${raw:0:2};  m=${raw:2:2} ;; # 0930 -> 09:30
            *)   return 1 ;;
        esac
    fi
    [[ $h =~ ^[0-9]+$ && $m =~ ^[0-9]+$ ]] || return 1
    h=$(( 10#$h )); m=$(( 10#$m ))
    if [[ -n $ap ]]; then
        (( h >= 1 && h <= 12 )) || return 1
        [[ $ap == pm && $h != 12 ]] && h=$(( h + 12 ))
        [[ $ap == am && $h == 12 ]] && h=0
    fi
    (( h >= 0 && h < 24 && m >= 0 && m < 60 )) || return 1
    printf '%02d:%02d' "$h" "$m"
}

# snap a minute value to a grid slot boundary (relative to the window start)
snap_min() {
    local m=$1 start=$2 slot=$3 off rem
    off=$(( m - start ))
    (( off < 0 )) && { printf '%d' "$start"; return; }
    rem=$(( off % slot ))
    if [[ $round == nearest && $rem -ge $(( (slot + 1) / 2 )) ]]; then
        printf '%d' "$(( start + off - rem + slot ))"
    else
        printf '%d' "$(( start + off - rem ))"
    fi
}

# format a duration in minutes -> "1h05m" / "20m"
fmt_dur() {
    local mins=$1 h m
    h=$(( mins / 60 )); m=$(( mins % 60 ))
    if (( h > 0 )); then printf '%dh%02dm' "$h" "$m"; else printf '%dm' "$m"; fi
}

# canonicalise a project name so trivially-different spellings don't split into
# separate projects: lowercase, drop stray tab/CR/newline, collapse internal
# whitespace runs to a single space, and trim the ends. "Backend", "backend",
# and "foo  bar" (two spaces) thus all land on one canonical name.
normalize_project() {
    local p=${1//[$'\t\r\n']/ }
    while [[ $p == *"  "* ]]; do p=${p//  / }; done   # squeeze runs of spaces
    p=${p#"${p%%[![:space:]]*}"}                      # ltrim
    p=${p%"${p##*[![:space:]]}"}                      # rtrim
    printf '%s' "${p,,}"
}

# detect project from git remote -> repo toplevel -> default, canonicalised
detect_project() {
    local p
    p=$(git remote get-url origin 2>/dev/null | sed 's#.*[/:]##; s/\.git$//') || true
    if [[ -z $p ]] && git rev-parse --show-toplevel >/dev/null 2>&1; then
        p=$(basename "$(git rev-parse --show-toplevel)")
    fi
    [[ -z $p ]] && p=$default_project
    normalize_project "$p"
}

# day file path for a YYYY-MM-DD date
day_file() {
    local d=$1
    printf '%s/%s/%s/%s.tsv' "$WJ_DATA_DIR" "${d:0:4}" "${d:5:2}" "${d:8:2}"
}

# the backlog file of pending (not-yet-started) tasks. Unlike the day logs this
# is mutable (add/drop/edit/reorder); line order is the user's manual priority.
# Columns: id  created  project  due  desc
pending_file() { printf '%s/pending.tsv' "$WJ_DATA_DIR"; }

# split a TSV line ($1) into PF[] preserving empty fields. `read -r a b c`
# with IFS=$'\t' can't be used here: tab is IFS-whitespace, so it merges
# consecutive tabs and drops empty columns (e.g. an empty project/due).
declare -a PF=()
tsv_split() {
    local line=$1
    PF=()
    while [[ $line == *$'\t'* ]]; do PF+=("${line%%$'\t'*}"); line=${line#*$'\t'}; done
    PF+=("$line")
}

# strip tab / CR / newline from a field so user text can't break the TSV layout
# (a stray tab shifts columns; a newline forges a whole phantom row).
sanitize() { local v=${1//[$'\t\r\n']/ }; printf '%s' "$v"; }

append_event() {
    local ts=$1 id=$2 proj=$3 evt=$4 note=${5:-} file
    proj=$(sanitize "$proj"); note=$(sanitize "$note")
    file=$(day_file "${ts:0:10}")
    mkdir -p "$(dirname "$file")"
    printf '%s\t%s\t%s\t%s\t%s\n' "$ts" "$id" "$proj" "$evt" "$note" >>"$file"
    _R_FILE="__stale__"   # invalidate the replay cache: the log just changed
}

# Serialize the read-derive-append sequence of mutating commands so two
# concurrent `wj` invocations can't interleave — e.g. both reading max_task_id as
# 2 and both minting T3, or two backlog edits racing on pending.tsv. The lock is
# held on fd 9 for the life of the (short-lived) process and released on exit.
#
# Best-effort: uses flock(1) when present (Linux/util-linux, the primary target)
# and is a silent no-op otherwise (e.g. macOS without flock), degrading to the
# prior unlocked behaviour rather than failing.
acquire_lock() {
    command -v flock >/dev/null 2>&1 || return 0
    mkdir -p "$WJ_DATA_DIR" 2>/dev/null || return 0
    # NB: the 2>/dev/null is scoped to the brace group, NOT placed directly on
    # the `exec` — `exec 9>f 2>/dev/null` (no command) would make BOTH
    # redirections permanent, silently sending all later stderr to /dev/null.
    { exec 9>"$WJ_DATA_DIR/.lock"; } 2>/dev/null || return 0
    flock 9 2>/dev/null || return 0
}

# ---------------------------------------------------------------------------
# Per-day replay queries
# ---------------------------------------------------------------------------
#
# replay_day does ONE pass over a day file and derives every per-task aggregate
# the read views need, memoized by file path. The task_* helpers below read from
# that cache, so rendering a day (status/grid/report/gantt/search) replays the
# file once instead of once per helper per task. append_event() marks the cache
# stale, and replay_day rebuilds on the next access of a different/changed file.
#
# Per-id arrays:  _R_DESC project _R_STATUS, _R_CANCEL (0|1),
#   _R_CLOSED (summed minutes of completed intervals), _R_ACTIVE (0|1, open?),
#   _R_OPEN (start-minute of the open interval). _R_IDS keeps first-seen order;
#   _R_SEEN marks membership.
_R_FILE="__none__"
declare -A _R_DESC=() _R_PROJ=() _R_STATUS=() _R_CANCEL=() _R_CLOSED=() _R_OPEN=() _R_ACTIVE=() _R_SEEN=()
declare -a _R_IDS=()
replay_day() {
    local file=$1
    [[ $_R_FILE == "$file" ]] && return 0
    _R_FILE=$file
    _R_DESC=(); _R_PROJ=(); _R_STATUS=(); _R_CANCEL=(); _R_CLOSED=(); _R_OPEN=(); _R_ACTIVE=(); _R_SEEN=(); _R_IDS=()
    [[ -f $file ]] || return 0
    local ts id proj evt note hh mm m
    while IFS=$'\t' read -r ts id proj evt note; do
        [[ -n $id ]] || continue
        if [[ -z ${_R_SEEN[$id]:-} ]]; then
            _R_SEEN[$id]=1; _R_IDS+=("$id")
            _R_CLOSED[$id]=0; _R_ACTIVE[$id]=0; _R_CANCEL[$id]=0
            _R_DESC[$id]=""; _R_PROJ[$id]=""; _R_STATUS[$id]=""
        fi
        hh=${ts:11:2}; mm=${ts:14:2}; m=$(( 10#$hh * 60 + 10#$mm ))
        case $evt in
            start)
                _R_DESC[$id]=$note; _R_PROJ[$id]=$proj; _R_STATUS[$id]=in-progress
                (( _R_ACTIVE[$id] )) || { _R_ACTIVE[$id]=1; _R_OPEN[$id]=$m; } ;;
            resume)
                _R_STATUS[$id]=in-progress
                (( _R_ACTIVE[$id] )) || { _R_ACTIVE[$id]=1; _R_OPEN[$id]=$m; } ;;
            amend) _R_DESC[$id]=$note ;;
            move)  _R_PROJ[$id]=$proj ;;
            pause|complete|defer)
                case $evt in pause) _R_STATUS[$id]=paused;; complete) _R_STATUS[$id]=completed;; defer) _R_STATUS[$id]=deferred;; esac
                (( _R_ACTIVE[$id] )) && { _R_CLOSED[$id]=$(( _R_CLOSED[$id] + m - _R_OPEN[$id] )); _R_ACTIVE[$id]=0; } ;;
            cancel)
                _R_STATUS[$id]=cancelled; _R_CANCEL[$id]=1; _R_ACTIVE[$id]=0 ;;
        esac
    done <"$file"
    return 0
}

# highest existing T# in a day file (0 if none)
max_task_id() {
    local file=$1 ts id rest n max=0
    [[ -f $file ]] || { echo 0; return; }
    while IFS=$'\t' read -r ts id rest; do
        n=${id#T}
        [[ $n =~ ^[0-9]+$ ]] && (( n > max )) && max=$n
    done <"$file"
    echo "$max"
}

# a task's description: its `start` note, overridden by the latest `amend`
task_desc() { replay_day "$1"; printf '%s' "${_R_DESC[$2]:-}"; }

# a task's project: its `start` project, overridden by the latest `move`
task_project() { replay_day "$1"; printf '%s' "${_R_PROJ[$2]:-}"; }

# whether a task has been cancelled (voided)
task_cancelled() { replay_day "$1"; [[ ${_R_CANCEL[$2]:-0} == 1 ]]; }

# current status of a task by last status-affecting event
task_status() { replay_day "$1"; printf '%s' "${_R_STATUS[$2]:-}"; }

# true if task $2 in file $1 is already in status $3. Used to keep the
# state-changing actions idempotent: repeating an action whose target state
# the task already holds (pause a paused task, resume a running one, …)
# appends nothing and is a no-op.
in_status() { [[ "$(task_status "$1" "$2")" == "$3" ]]; }

# distinct task ids in a day file, in first-seen (numeric) order
task_ids() {
    local file=$1 ts id rest
    [[ -f $file ]] || return 0
    awk -F'\t' '!seen[$2]++ {print $2}' "$file"
}

# total active minutes for a task; arg3 = now-minute (cap for open intervals)
task_minutes() {
    local file=$1 want=$2 now_min=$3 total slot=$slot_minutes
    replay_day "$file"
    [[ -n ${_R_SEEN[$want]:-} ]] || { printf '0'; return; }
    (( ${_R_CANCEL[$want]} )) && { printf '0'; return; }
    total=${_R_CLOSED[$want]}
    (( ${_R_ACTIVE[$want]} )) && total=$(( total + now_min - _R_OPEN[$want] ))
    if [[ $totals == slot ]]; then
        total=$(( (total + slot - 1) / slot * slot ))
    fi
    (( total < 0 )) && total=0
    printf '%d' "$total"
}

# whether a task id appears in a day file
task_exists() {
    replay_day "$1"
    [[ -n ${_R_SEEN[$2]:-} ]]
}

# --- grid window & open-interval cap ----------------------------------------
# The grid/gantt are framed by an effective [start,end] window. shift_start /
# shift_end (when set) are only the *default* frame: the window always expands
# to fit the day's real activity, and when the bounds are unset (commented out
# in the config) the frame is dropped entirely and the window auto-fits the day.

# round a minute-of-day down / up to the hour
floor_hour() { printf '%d' "$(( $1 / 60 * 60 ))"; }
ceil_hour()  { printf '%d' "$(( ($1 + 59) / 60 * 60 ))"; }

# earliest and latest event minute among a day's non-cancelled tasks, printed
# as "lo hi" (nothing when the day has no such events).
day_span() {
    local file=$1 ts id proj evt note m lo="" hi=""
    [[ -f $file ]] || return 0
    replay_day "$file"
    while IFS=$'\t' read -r ts id proj evt note; do
        [[ -n $id ]] || continue
        (( ${_R_CANCEL[$id]:-0} )) && continue
        m=$(( 10#${ts:11:2} * 60 + 10#${ts:14:2} ))
        [[ -z $lo || $m -lt $lo ]] && lo=$m
        [[ -z $hi || $m -gt $hi ]] && hi=$m
    done <"$file"
    [[ -n $lo ]] && printf '%d %d' "$lo" "$hi"
}

# the cap minute for open intervals (and the now-marker) on a day:
#   today      -> the current wall clock
#   a past day -> that day's last recorded event, so a task left open is counted
#                 only up to the last known activity, never silently extended to
#                 a guessed shift end. Falls back to shift_end / 19:00 only when
#                 the day has no events at all.
report_nm() {
    local d=$1 file=$2 span
    if [[ $d == "$TODAY" ]]; then now_min; return; fi
    span=$(day_span "$file")
    [[ -n $span ]] && { printf '%d' "${span##* }"; return; }
    hm_to_min "${shift_end:-19:00}"
}

# effective grid window "start end" (minutes) for a day: the configured shift
# bounds (when set) expanded out to whole hours around the day's activity (and
# the open-interval cap nm). With no bounds set it auto-fits the activity; with
# no activity at all it falls back to the configured-or-default 09:00–19:00.
grid_window() {
    local file=$1 nm=$2 span lo hi s="" e="" flo fhi
    [[ -n $shift_start ]] && s=$(hm_to_min "$shift_start")
    [[ -n $shift_end   ]] && e=$(hm_to_min "$shift_end")
    span=$(day_span "$file")
    if [[ -n $span ]]; then
        lo=${span%% *}; hi=${span##* }
        [[ -n $nm && $nm -gt $hi ]] && hi=$nm
        flo=$(floor_hour "$lo"); fhi=$(ceil_hour "$hi")
        [[ -z $s || $flo -lt $s ]] && s=$flo
        [[ -z $e || $fhi -gt $e ]] && e=$fhi
    fi
    [[ -n $s ]] || s=$(hm_to_min "${shift_start:-09:00}")
    [[ -n $e ]] || e=$(hm_to_min "${shift_end:-19:00}")
    (( e > s )) || e=$(( s + 60 ))
    printf '%d %d' "$s" "$e"
}

# resolve a task by current state: mode=active (in-progress) | resumable (paused/deferred).
# Returns the most-recently-transitioned matching task, optionally filtered by project.
# Correctly handles several concurrently-active tasks across projects.
# effective auto-pause for this invocation: the per-command --parallel /
# --auto-pause flags win over the config default. Returns 0 when a start/resume
# should auto-pause the project's other running task, 1 when they run in parallel.
autopause_on() {
    [[ ${PAUSE_OVERRIDE:-$auto_pause} == on ]]
}

find_task() {
    local file=$1 mode=$2 proj=$3 ts id p evt note seq=0
    [[ -f $file ]] || return 0
    declare -A status=() lastseq=() pproj=()
    while IFS=$'\t' read -r ts id p evt note; do
        # move re-homes the task's project without being a state transition
        [[ $evt == move ]] && { pproj[$id]=$p; continue; }
        case $evt in
            start|resume) status[$id]=active ;;
            pause)        status[$id]=paused ;;
            defer)        status[$id]=deferred ;;
            complete)     status[$id]=completed ;;
            cancel)       status[$id]=cancelled ;;
            *)            continue ;;
        esac
        seq=$(( seq + 1 )); lastseq[$id]=$seq; pproj[$id]=$p
    done <"$file"
    local best="" bestseq=-1 k ok
    for k in "${!status[@]}"; do
        ok=0
        case $mode in
            active)    [[ ${status[$k]} == active ]] && ok=1 ;;
            resumable) [[ ${status[$k]} == paused || ${status[$k]} == deferred ]] && ok=1 ;;
        esac
        (( ok )) || continue
        [[ -n $proj && ${pproj[$k]} != "$proj" ]] && continue
        (( lastseq[$k] > bestseq )) && { best=$k; bestseq=${lastseq[$k]}; }
    done
    printf '%s' "$best"
}

# ---------------------------------------------------------------------------
# Argument parsing — extract global flags, leave positionals in ARGS[]
# ---------------------------------------------------------------------------
AT=""; ON=""; PROJECT_OVERRIDE=""; FROM=""; TO=""; FORMAT="csv"; BY="project"; DAYS=""; DUE=""; JSON=0; PAUSE_OVERRIDE=""
declare -a ARGS=()
need_val() { [[ $# -ge 2 ]] || die "$1 needs a value"; }
# whether $1 is a real calendar date in YYYY-MM-DD form. GNU `date -d` would
# silently roll over 2026-02-31 / 2026-13-99, so we round-trip and compare.
valid_date() {
    [[ $1 =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]] || return 1
    local norm
    norm=$(date -d "$1" +%Y-%m-%d 2>/dev/null) || return 1
    [[ $norm == "$1" ]]
}
parse_args() {
    while (( $# )); do
        case $1 in
            --at)       need_val "$@"; AT=$2;       shift 2 ;;
            --date|--on) need_val "$@"; ON=$2;      shift 2 ;;
            --project)  need_val "$@"; PROJECT_OVERRIDE=$2; shift 2 ;;
            --from)     need_val "$@"; FROM=$2;     shift 2 ;;
            --to)       need_val "$@"; TO=$2;       shift 2 ;;
            --format)   need_val "$@"; FORMAT=$2;   shift 2 ;;
            --by)       need_val "$@"; BY=$2;       shift 2 ;;
            --days)     need_val "$@"; DAYS=$2;     shift 2 ;;
            --due)      need_val "$@"; DUE=$2;      shift 2 ;;
            --json)     JSON=1;                     shift ;;
            --parallel)   PAUSE_OVERRIDE=off;        shift ;;
            --auto-pause) PAUSE_OVERRIDE=on;         shift ;;
            --)         shift; while (( $# )); do ARGS+=("$1"); shift; done ;;
            *)          ARGS+=("$1"); shift ;;
        esac
    done
    if [[ -n $AT ]]; then
        local norm
        norm=$(normalize_time "$AT") || die "--at: cannot parse '$AT' (examples: 9, 930, 9:30, 9pm, 9.30)"
        AT=$norm
    fi
    [[ -z $ON ]] || valid_date "$ON" || die "--date must be a real date YYYY-MM-DD (got '$ON')"
    # canonicalise the project once so it matches the auto-detected form and is
    # consistent everywhere it is used (as the task's project AND as a scope filter).
    [[ -z $PROJECT_OVERRIDE ]] || PROJECT_OVERRIDE=$(normalize_project "$PROJECT_OVERRIDE")
}

TODAY=$(date +%Y-%m-%d)

# last event's HH:MM in a day file ("" if none)
last_event_time() {
    local file=$1 ts rest last=""
    [[ -f $file ]] || return 0
    while IFS=$'\t' read -r ts rest; do
        [[ -n $ts ]] && last=${ts:11:5}
    done <"$file"
    printf '%s' "$last"
}

# effective HH:MM for an action:
#   --at given            -> that time
#   past --date, no --at  -> continue from the day's last event (else shift_start),
#                            with a one-time note so the inference is never silent
#   otherwise             -> now
INFER_NOTED=0
eff_time() {
    if [[ -n $AT ]]; then printf '%s' "$AT"; return; fi
    if [[ -n $ON && $ON != "$TODAY" ]]; then
        local t; t=$(last_event_time "$(day_file "$ON")")
        [[ -n $t ]] || t=${shift_start:-09:00}
        (( INFER_NOTED )) || { printf 'wj: no --at; using %s for %s\n' "$t" "$ON" >&2; INFER_NOTED=1; }
        printf '%s' "$t"; return
    fi
    date +%H:%M
}
now_ts()  { printf '%sT%s' "${ON:-$TODAY}" "$(eff_time)"; }
now_min() { hm_to_min "$(eff_time)"; }
cur_project() {
    if [[ -n $PROJECT_OVERRIDE ]]; then printf '%s' "$PROJECT_OVERRIDE"; else detect_project; fi
}

# build the wj-tui -colors value from the configured per-panel colors, skipping
# any that are empty so the TUI keeps its built-in default for them.
ui_colorspec() {
    local out="" name var val
    for name in projects tasks pending range day timeline; do
        var="color_$name"; val=${!var:-}
        [[ -n $val ]] || continue
        out+="${out:+,}$name=$val"
    done
    printf '%s' "$out"
}

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------
cmd_start() {
    local desc
    if [[ ${ARGS[0]:-} =~ ^P[0-9]+$ ]]; then
        # promote a pending task: carry its description + project, then drop it
        local pid=${ARGS[0]}
        pending_get "$pid" || die "no such pending task: $pid"
        desc=$PEND_DESC
        [[ -n $PROJECT_OVERRIDE ]] || PROJECT_OVERRIDE=$PEND_PROJ
        pending_remove "$pid"
    else
        desc=${ARGS[*]:-}
    fi
    [[ -n $desc ]] || die "start needs a description"
    local proj ts file id active
    proj=$(cur_project); ts=$(now_ts); file=$(day_file "${ts:0:10}")
    # auto-pause any in-progress task in the same project (unless running parallel)
    if autopause_on; then
        active=$(find_task "$file" active "$proj")
        [[ -n $active ]] && append_event "$ts" "$active" "$proj" pause "auto-paused (started new task)"
    fi
    id="T$(( $(max_task_id "$file") + 1 ))"
    append_event "$ts" "$id" "$proj" start "$desc"
    printf '%s  %s  [%s]  started %s — %s\n' "$id" "${ts:11:5}" "$proj" "$id" "$desc"
}

# continue a past day's task as a fresh task TODAY. --date picks the source day
# (required); we copy that task's description and project into a brand-new T#
# written to today, and append a `log` event recording the lineage. The write is
# always today (ON is the *source*, never the write target); --at sets its start
# time, --project overrides the carried-over project. Task ids are per-day, so
# the new task gets today's next id — the original is left untouched.
cmd_continue() {
    local id=${ARGS[0]:-} src desc proj
    [[ -n $id ]] || die "continue needs a task id (e.g. wj continue T1 --date 2026-06-02)"
    [[ $id =~ ^T[0-9]+$ ]] || die "not a task id: $id (e.g. T1)"
    [[ -n $ON ]] || die "continue needs --date YYYY-MM-DD (the day to copy the task from)"
    [[ $ON != "$TODAY" ]] || die "continue copies from a past day; use resume/start for today's tasks"
    src=$(day_file "$ON")
    task_exists "$src" "$id" || die "no such task on $ON: $id"
    desc=$(task_desc "$src" "$id")
    proj=$(task_project "$src" "$id")
    [[ -n $PROJECT_OVERRIDE ]] || PROJECT_OVERRIDE=$proj
    # write to today, not ON: build the timestamp from today + (--at | now).
    local wts wfile newid active
    wts="${TODAY}T${AT:-$(date +%H:%M)}"
    wfile=$(day_file "$TODAY")
    if autopause_on; then
        active=$(find_task "$wfile" active "$PROJECT_OVERRIDE")
        [[ -n $active ]] && append_event "$wts" "$active" "$PROJECT_OVERRIDE" pause "auto-paused (continued $id)"
    fi
    newid="T$(( $(max_task_id "$wfile") + 1 ))"
    append_event "$wts" "$newid" "$PROJECT_OVERRIDE" start "$desc"
    append_event "$wts" "$newid" "$PROJECT_OVERRIDE" log "continued from $ON $id"
    printf '%s  %s  [%s]  started %s — %s  (continued from %s %s)\n' \
        "$newid" "${wts:11:5}" "$PROJECT_OVERRIDE" "$newid" "$desc" "$ON" "$id"
}

cmd_pause() {
    local ts file proj id reason
    ts=$(now_ts); file=$(day_file "${ts:0:10}"); proj=$PROJECT_OVERRIDE
    if [[ ${ARGS[0]:-} =~ ^T[0-9]+$ ]]; then id=${ARGS[0]}; reason=${ARGS[*]:1}
        task_exists "$file" "$id" || die "no such task today: $id"
    else id=$(find_task "$file" active "$proj"); reason=${ARGS[*]:-}; fi
    [[ -n $id ]] || die "no in-progress task${PROJECT_OVERRIDE:+ in $proj} to pause"
    in_status "$file" "$id" paused && { printf '%s  already paused\n' "$id"; return 0; }
    append_event "$ts" "$id" "$(task_project "$file" "$id")" pause "$reason"
    printf '%s  %s  paused%s\n' "$id" "${ts:11:5}" "${reason:+ — $reason}"
}

cmd_resume() {
    local ts file proj id
    ts=$(now_ts); file=$(day_file "${ts:0:10}"); proj=$PROJECT_OVERRIDE
    if [[ ${ARGS[0]:-} =~ ^T[0-9]+$ ]]; then id=${ARGS[0]}
        task_exists "$file" "$id" || die "no such task today: $id"
    else id=$(find_task "$file" resumable "$proj"); fi
    [[ -n $id ]] || die "no paused/deferred task to resume"
    in_status "$file" "$id" in-progress && { printf '%s  already in-progress\n' "$id"; return 0; }
    local tproj; tproj=$(task_project "$file" "$id")
    # auto-pause an in-progress task in that project first (unless running parallel)
    if autopause_on; then
        local active; active=$(find_task "$file" active "$tproj")
        [[ -n $active && $active != "$id" ]] && append_event "$ts" "$active" "$tproj" pause "auto-paused (resumed $id)"
    fi
    append_event "$ts" "$id" "$tproj" resume ""
    printf '%s  %s  resumed — %s\n' "$id" "${ts:11:5}" "$(task_desc "$file" "$id")"
}

cmd_defer() {
    local ts file proj id reason
    ts=$(now_ts); file=$(day_file "${ts:0:10}"); proj=$PROJECT_OVERRIDE
    if [[ ${ARGS[0]:-} =~ ^T[0-9]+$ ]]; then id=${ARGS[0]}; reason=${ARGS[*]:1}
        task_exists "$file" "$id" || die "no such task today: $id"
    else id=$(find_task "$file" active "$proj"); reason=${ARGS[*]:-}; fi
    [[ -n $id ]] || die "no task to defer (give a task id)"
    in_status "$file" "$id" deferred && { printf '%s  already deferred\n' "$id"; return 0; }
    append_event "$ts" "$id" "$(task_project "$file" "$id")" defer "$reason"
    printf '%s  %s  deferred%s\n' "$id" "${ts:11:5}" "${reason:+ — $reason}"
}

cmd_log() {
    local ts file proj id note
    ts=$(now_ts); file=$(day_file "${ts:0:10}"); proj=$PROJECT_OVERRIDE
    note=${ARGS[*]:-}
    [[ -n $note ]] || die "log needs a note"
    id=$(find_task "$file" active "$proj")
    [[ -n $id ]] || die "no active task to log against"
    append_event "$ts" "$id" "$(task_project "$file" "$id")" log "$note"
    printf '%s  %s  note added\n' "$id" "${ts:11:5}"
}

cmd_amend() {
    local ts file proj id desc
    ts=$(now_ts); file=$(day_file "${ts:0:10}"); proj=$PROJECT_OVERRIDE
    if [[ ${ARGS[0]:-} =~ ^T[0-9]+$ ]]; then id=${ARGS[0]}; desc=${ARGS[*]:1}
        task_exists "$file" "$id" || die "no such task today: $id"
    else id=$(find_task "$file" active "$proj"); desc=${ARGS[*]:-}; fi
    [[ -n $id ]] || die "no task to amend (give a task id)"
    [[ -n $desc ]] || die "amend needs a new description"
    append_event "$ts" "$id" "$(task_project "$file" "$id")" amend "$desc"
    printf '%s  %s  amended — %s\n' "$id" "${ts:11:5}" "$desc"
}

cmd_move() {
    local ts file proj id newproj oldproj
    ts=$(now_ts); file=$(day_file "${ts:0:10}"); proj=$PROJECT_OVERRIDE
    if [[ ${ARGS[0]:-} =~ ^T[0-9]+$ ]]; then id=${ARGS[0]}; newproj=${ARGS[*]:1}
        task_exists "$file" "$id" || die "no such task today: $id"
    else id=$(find_task "$file" active "$proj"); newproj=${ARGS[*]:-}; fi
    [[ -n $id ]] || die "no task to move (give a task id)"
    [[ -n $newproj ]] || die "move needs a target project"
    newproj=$(normalize_project "$newproj")
    [[ -n $newproj ]] || die "move needs a target project"
    oldproj=$(task_project "$file" "$id")
    # new project in the project column; old kept in the note for audit
    append_event "$ts" "$id" "$newproj" move "$oldproj"
    printf '%s  %s  moved  %s -> %s\n' "$id" "${ts:11:5}" "$oldproj" "$newproj"
}

cmd_cancel() {
    local ts file proj id
    ts=$(now_ts); file=$(day_file "${ts:0:10}"); proj=$PROJECT_OVERRIDE
    if [[ ${ARGS[0]:-} =~ ^T[0-9]+$ ]]; then id=${ARGS[0]}
        task_exists "$file" "$id" || die "no such task today: $id"
    else id=$(find_task "$file" active "$proj"); fi
    [[ -n $id ]] || die "no task to cancel (give a task id)"
    in_status "$file" "$id" cancelled && { printf '%s  already cancelled\n' "$id"; return 0; }
    append_event "$ts" "$id" "$(task_project "$file" "$id")" cancel ""
    printf '%s  %s  cancelled (voided — hidden from status/grid/report)\n' "$id" "${ts:11:5}"
}

cmd_complete() {
    local ts file proj id
    ts=$(now_ts); file=$(day_file "${ts:0:10}"); proj=$PROJECT_OVERRIDE
    if [[ ${ARGS[0]:-} =~ ^T[0-9]+$ ]]; then id=${ARGS[0]}
        task_exists "$file" "$id" || die "no such task today: $id"
    else id=$(find_task "$file" active "$proj"); fi
    [[ -n $id ]] || die "no in-progress task${PROJECT_OVERRIDE:+ in $proj} to complete"
    in_status "$file" "$id" completed && { printf '%s  already completed\n' "$id"; return 0; }
    local tproj; tproj=$(task_project "$file" "$id")
    append_event "$ts" "$id" "$tproj" complete ""
    local mins; mins=$(task_minutes "$file" "$id" "$(now_min)")
    printf '%s  %s  completed — %s\n' "$id" "${ts:11:5}" "$(fmt_dur "$mins")"
}

# list open tasks (last event not complete/cancel).
#   wj ls            -> today (or --date) only
#   wj ls --days N   -> scan the last N days, with a DATE column
cmd_ls() {
    local days=${DAYS:-1} base=${ON:-$TODAY}
    [[ $days =~ ^[0-9]+$ && $days -ge 1 ]] || die "--days must be a positive integer"
    local wide=0; (( days > 1 )) && wide=1

    local -a dates=(); local d=$base i
    for (( i=0; i<days; i++ )); do dates+=("$d"); d=$(date -d "$d -1 day" +%Y-%m-%d); done

    printf '\nOpen tasks'
    if (( wide )); then printf ' — last %d days (through %s)\n\n' "$days" "$base"
    else printf ' — %s\n\n' "$base"; fi
    if (( wide )); then
        printf '%-10s  %-4s  %-16s  %-12s  %-7s  %s\n' DATE ID PROJECT STATUS TIME DESCRIPTION
        printf '%-10s  %-4s  %-16s  %-12s  %-7s  %s\n' ---------- ---- ---------------- ------------ ------- -----------
    else
        printf '%-4s  %-16s  %-12s  %-7s  %s\n' ID PROJECT STATUS TIME DESCRIPTION
        printf '%-4s  %-16s  %-12s  %-7s  %s\n' ---- ---------------- ------------ ------- -----------
    fi

    local found=0 dd file id nm st p mins desc
    for dd in "${dates[@]}"; do
        file=$(day_file "$dd")
        [[ -f $file ]] || continue
        nm=$(report_nm "$dd" "$file")
        while read -r id; do
            [[ -z $id ]] && continue
            st=$(task_status "$file" "$id")
            case $st in in-progress|paused|deferred) ;; *) continue ;; esac
            p=$(task_project "$file" "$id")
            mins=$(task_minutes "$file" "$id" "$nm")
            desc=$(task_desc "$file" "$id")
            if (( wide )); then
                printf '%-10s  %-4s  %-16.16s  %-12s  %-7s  %s\n' "$dd" "$id" "$p" "$st" "$(fmt_dur "$mins")" "$desc"
            else
                printf '%-4s  %-16.16s  %-12s  %-7s  %s\n' "$id" "$p" "$st" "$(fmt_dur "$mins")" "$desc"
            fi
            found=1
        done < <(task_ids "$file")
    done
    (( found )) || printf '  (none)\n'
    printf '\n'
}

# full timeline of one task (today by default; --date for a past day)
cmd_show() {
    local d=${ON:-$TODAY} id=${ARGS[0]:-} file
    [[ -n $id ]] || die "show needs a task id (e.g. wj show T2)"
    [[ $id =~ ^T[0-9]+$ ]] || die "not a task id: $id"
    file=$(day_file "$d")
    task_exists "$file" "$id" || die "no such task on $d: $id"
    local nm; nm=$(report_nm "$d" "$file")
    (( JSON )) && { json_show "$d" "$file" "$id" "$nm"; return; }
    local proj st mins desc
    proj=$(task_project "$file" "$id")
    st=$(task_status "$file" "$id")
    mins=$(task_minutes "$file" "$id" "$nm")
    desc=$(task_desc "$file" "$id")
    printf '\n%s  [%s]  %s\n' "$id" "$proj" "$desc"
    printf '%s · %s · %s\n\n' "$d" "$st" "$(fmt_dur "$mins")"
    printf 'TIMELINE\n'
    local ts xid xp evt note t label extra
    while IFS=$'\t' read -r ts xid xp evt note; do
        [[ $xid == "$id" ]] || continue
        t=${ts:11:5}; extra=""
        case $evt in
            start)    label=started;   extra=$note ;;
            resume)   label=resumed ;;
            pause)    label=paused;     extra=${note:+— $note} ;;
            defer)    label=deferred;   extra=${note:+— $note} ;;
            log)      label=note;       extra=$note ;;
            amend)    label=renamed;    extra=$note ;;
            move)     label=moved;      extra="$note -> $xp" ;;
            cancel)   label=cancelled ;;
            complete) label=completed ;;
            *)        continue ;;
        esac
        printf '  %s  %-9s  %s\n' "$t" "$label" "$extra"
    done <"$file"
    printf '\n'
}

cmd_status() {
    local d=${ARGS[0]:-${ON:-$TODAY}} file ids id nm
    file=$(day_file "$d")
    nm=$(report_nm "$d" "$file")
    (( JSON )) && { json_status "$d" "$file" "$nm"; return; }
    [[ -f $file ]] || { printf 'No tasks for %s\n' "$d"; return; }
    printf '\nTasks — %s\n\n' "$d"
    printf '%-4s  %-16s  %-12s  %-7s  %s\n' ID PROJECT STATUS TIME DESCRIPTION
    printf '%-4s  %-16s  %-12s  %-7s  %s\n' ---- ---------------- ------------ ------- -----------
    while read -r id; do
        [[ -z $id ]] && continue
        task_cancelled "$file" "$id" && continue
        local p st mins desc
        p=$(task_project "$file" "$id")
        st=$(task_status "$file" "$id")
        mins=$(task_minutes "$file" "$id" "$nm")
        desc=$(task_desc "$file" "$id")
        printf '%-4s  %-16.16s  %-12s  %-7s  %s\n' "$id" "$p" "$st" "$(fmt_dur "$mins")" "$desc"
    done < <(task_ids "$file")
    # day total
    local tot=0
    while read -r id; do
        [[ -z $id ]] && continue
        task_cancelled "$file" "$id" && continue
        tot=$(( tot + $(task_minutes "$file" "$id" "$nm") ))
    done < <(task_ids "$file")
    printf '\nTotal tracked: %s\n\n' "$(fmt_dur "$tot")"
}

cmd_grid() {
    local d=${ARGS[0]:-${ON:-$TODAY}} file
    file=$(day_file "$d")
    local start end slot nm
    slot=$slot_minutes
    nm=$(report_nm "$d" "$file")
    read -r start end < <(grid_window "$file" "$nm")
    (( JSON )) && { json_grid "$d" "$file" "$nm" "$start" "$end"; return; }
    [[ -f $file ]] || { printf 'No tasks for %s\n' "$d"; return; }

    # collect ids (cancelled tasks are voided — omit them)
    local -a ids=()
    while read -r i; do
        [[ -n $i ]] || continue
        task_cancelled "$file" "$i" && continue
        ids+=("$i")
    done < <(task_ids "$file")
    (( ${#ids[@]} )) || { printf 'No tasks for %s\n' "$d"; return; }

    # build cell map  CELL[id:slotmin]=symbol
    declare -A CELL=()
    local id
    for id in "${ids[@]}"; do
        local ts xid proj evt note m active=0 open=0 s
        while IFS=$'\t' read -r ts xid proj evt note; do
            [[ $xid == "$id" ]] || continue
            m=$(snap_min "$(hm_to_min "${ts:11:5}")" "$start" "$slot")
            case $evt in
                start|resume) (( active )) || { active=1; open=$m; } ;;
                pause|complete|defer)
                    if (( active )); then
                        for (( s=open; s<m; s+=slot )); do CELL[$id:$s]='>>'; done
                        active=0
                    fi
                    case $evt in pause) CELL[$id:$m]='--';; complete) CELL[$id:$m]='**';; defer) CELL[$id:$m]='~~';; esac ;;
            esac
        done <"$file"
        if (( active )); then
            local cap; cap=$(snap_min "$nm" "$start" "$slot")
            for (( s=open; s<=cap; s+=slot )); do CELL[$id:$s]='>>'; done
        fi
    done

    # header
    printf '\nSchedule — %s   (legend: >> active  -- paused  ** done  ~~ deferred)\n\n' "$d"
    printf '| Time  '
    for id in "${ids[@]}"; do printf '| %-3s' "$id"; done
    printf '|\n|-------'
    for id in "${ids[@]}"; do printf '|----'; done
    printf '|\n'
    local t
    for (( t=start; t<=end; t+=slot )); do
        printf '| %s ' "$(min_to_hm "$t")"
        for id in "${ids[@]}"; do printf '| %-3s' "${CELL[$id:$t]:-}"; done
        printf '|\n'
    done
    printf '\n'
    # legend of task ids
    for id in "${ids[@]}"; do
        printf '%-4s %-14s %s\n' "$id" "[$(task_project "$file" "$id")]" "$(task_desc "$file" "$id")"
    done
    printf '\n'
}

# iterate dates from $1 to $2 inclusive (YYYY-MM-DD), echo each
iter_dates() {
    local d=$1 end=$2
    while [[ $d < $end || $d == "$end" ]]; do
        echo "$d"
        d=$(date -d "$d +1 day" +%Y-%m-%d)
    done
}

cmd_report() {
    local from=${FROM:-$TODAY} to=${TO:-$TODAY}
    declare -A AGG=()
    local d file id nm key
    while read -r d; do
        file=$(day_file "$d")
        [[ -f $file ]] || continue
        nm=$(report_nm "$d" "$file")
        while read -r id; do
            [[ -z $id ]] && continue
            task_cancelled "$file" "$id" && continue
            case $BY in
                project) key=$(task_project "$file" "$id") ;;
                task)    key="$id  $(task_desc "$file" "$id")" ;;
                day)     key=$d ;;
                *)       die "--by must be project|task|day" ;;
            esac
            AGG[$key]=$(( ${AGG[$key]:-0} + $(task_minutes "$file" "$id" "$nm") ))
        done < <(task_ids "$file")
    done < <(iter_dates "$from" "$to")
    printf '\nReport %s..%s  by %s\n\n' "$from" "$to" "$BY"
    local k tot=0
    for k in "${!AGG[@]}"; do tot=$(( tot + AGG[$k] )); done
    for k in "${!AGG[@]}"; do printf '%s\t%s\n' "$(fmt_dur "${AGG[$k]}")" "$k"; done \
        | sort -t$'\t' -k2 | awk -F'\t' '{printf "  %-8s  %s\n", $1, $2}'
    printf '\n  %-8s  TOTAL\n\n' "$(fmt_dur "$tot")"
}

csv_escape()  { printf '"%s"' "$(printf '%s' "$1" | sed 's/"/""/g')"; }

# quote+escape a string as a JSON value (pure bash, no subshell).
# C0 control characters are escaped as \uXXXX so the output is always valid
# JSON even if a description/note ever contains one (e.g. a pasted byte).
_JSON_CTL=$'\x01\x02\x03\x04\x05\x06\x07\x08\x0b\x0c\x0e\x0f\x10\x11\x12\x13\x14\x15\x16\x17\x18\x19\x1a\x1b\x1c\x1d\x1e\x1f'
json_str() {
    local s=${1-}
    s=${s//\\/\\\\}
    s=${s//\"/\\\"}
    s=${s//$'\t'/\\t}
    s=${s//$'\r'/\\r}
    s=${s//$'\n'/\\n}
    # only walk char-by-char (slow) when a residual control char is present
    if [[ $s == *[$_JSON_CTL]* ]]; then
        local out="" i c
        for (( i=0; i<${#s}; i++ )); do
            c=${s:i:1}
            case $c in [$_JSON_CTL]) printf -v c '\\u%04x' "'$c" ;; esac
            out+=$c
        done
        s=$out
    fi
    printf '"%s"' "$s"
}

# ---------------------------------------------------------------------------
# JSON emitters — the machine-readable read contract consumed by the wj-tui
# front-end. All derivation (status, minutes, segments, aggregation) is reused
# from the same replay helpers the text views use, so the two never diverge.
# ---------------------------------------------------------------------------

# status JSON for a day: per-task totals + day total
json_status() {
    local d=$1 file=$2 nm=$3
    printf '{"date":%s,"now":%s,"tasks":[' "$(json_str "$d")" "$(json_str "$(min_to_hm "$nm")")"
    local first=1 id p st mins desc tot=0
    if [[ -f $file ]]; then
        while read -r id; do
            [[ -z $id ]] && continue
            task_cancelled "$file" "$id" && continue
            p=$(task_project "$file" "$id"); st=$(task_status "$file" "$id")
            mins=$(task_minutes "$file" "$id" "$nm"); desc=$(task_desc "$file" "$id")
            tot=$(( tot + mins ))
            (( first )) && first=0 || printf ','
            printf '{"id":%s,"project":%s,"status":%s,"minutes":%d,"desc":%s}' \
                "$(json_str "$id")" "$(json_str "$p")" "$(json_str "$st")" "$mins" "$(json_str "$desc")"
        done < <(task_ids "$file")
    fi
    printf '],"total_minutes":%d}\n' "$tot"
}

# full event timeline of one task
json_show() {
    local d=$1 file=$2 id=$3 nm=$4
    printf '{"id":%s,"date":%s,"project":%s,"status":%s,"desc":%s,"minutes":%d,"events":[' \
        "$(json_str "$id")" "$(json_str "$d")" "$(json_str "$(task_project "$file" "$id")")" \
        "$(json_str "$(task_status "$file" "$id")")" "$(json_str "$(task_desc "$file" "$id")")" \
        "$(task_minutes "$file" "$id" "$nm")"
    local first=1 ts xid xp evt note
    while IFS=$'\t' read -r ts xid xp evt note; do
        [[ $xid == "$id" ]] || continue
        (( first )) && first=0 || printf ','
        printf '{"time":%s,"event":%s,"project":%s,"note":%s}' \
            "$(json_str "${ts:11:5}")" "$(json_str "$evt")" "$(json_str "$xp")" "$(json_str "$note")"
    done <"$file"
    printf ']}\n'
}

# a task's active intervals as JSON segments. `to` of an ongoing interval is
# capped at `nm`; `state` records how the interval ended (or "active" if open).
json_segments() {
    local file=$1 want=$2 nm=$3
    local ts id proj evt note m active=0 open=0 first=1
    printf '['
    while IFS=$'\t' read -r ts id proj evt note; do
        [[ $id == "$want" ]] || continue
        m=$(hm_to_min "${ts:11:5}")
        case $evt in
            start|resume) (( active )) || { active=1; open=$m; } ;;
            pause|complete|defer)
                if (( active )); then
                    (( first )) && first=0 || printf ','
                    printf '{"from":%s,"to":%s,"state":%s}' \
                        "$(json_str "$(min_to_hm "$open")")" "$(json_str "$(min_to_hm "$m")")" "$(json_str "$evt")"
                    active=0
                fi ;;
            cancel) active=0 ;;
        esac
    done <"$file"
    # ongoing interval: only emit a positive-duration bar (open may exceed nm
    # for a task back-dated past the cap, which task_minutes clamps to 0 too)
    if (( active && open < nm )); then
        (( first )) && first=0 || printf ','
        printf '{"from":%s,"to":%s,"state":"active"}' \
            "$(json_str "$(min_to_hm "$open")")" "$(json_str "$(min_to_hm "$nm")")"
    fi
    printf ']'
}

# intraday grid JSON: per-task segments for the Gantt drill-down view
json_grid() {
    local d=$1 file=$2 nm=$3 start=$4 end=$5
    # shift_start/shift_end here are the *effective* grid window (the configured
    # bounds expanded to fit the day, or auto-fit when unset) so the TUI axis
    # always frames every bar — never clipping work tracked outside shift hours.
    printf '{"date":%s,"shift_start":%s,"shift_end":%s,"slot_minutes":%d,"now":%s,"tasks":[' \
        "$(json_str "$d")" "$(json_str "$(min_to_hm "$start")")" "$(json_str "$(min_to_hm "$end")")" \
        "$slot_minutes" "$(json_str "$(min_to_hm "$nm")")"
    local first=1 id
    if [[ -f $file ]]; then
        while read -r id; do
            [[ -z $id ]] && continue
            task_cancelled "$file" "$id" && continue
            (( first )) && first=0 || printf ','
            printf '{"id":%s,"project":%s,"desc":%s,"status":%s,"minutes":%d,"segments":%s}' \
                "$(json_str "$id")" "$(json_str "$(task_project "$file" "$id")")" \
                "$(json_str "$(task_desc "$file" "$id")")" "$(json_str "$(task_status "$file" "$id")")" \
                "$(task_minutes "$file" "$id" "$nm")" "$(json_segments "$file" "$id" "$nm")"
        done < <(task_ids "$file")
    fi
    printf ']}\n'
}

# ---------------------------------------------------------------------------
# gantt — multi-day range overview: rows (project|task) x days -> minutes.
# A 2-D pivot of the report aggregation; the headline view of the wj-tui UI.
# ---------------------------------------------------------------------------
cmd_gantt() {
    local to=${TO:-${ON:-$TODAY}} from=${FROM:-}
    [[ -n $from ]] || from=$(date -d "$to -6 day" +%Y-%m-%d)   # default: last 7 days
    case $BY in project|task) ;; *) die "--by must be project|task" ;; esac

    local -a days=(); local d
    while read -r d; do days+=("$d"); done < <(iter_dates "$from" "$to")

    declare -A AGG=() LABEL=() RTOTAL=() PROJ=()
    local -a rows=()
    local file id nm key lbl proj m
    for d in "${days[@]}"; do
        file=$(day_file "$d")
        [[ -f $file ]] || continue
        nm=$(report_nm "$d" "$file")
        while read -r id; do
            [[ -z $id ]] && continue
            task_cancelled "$file" "$id" && continue
            proj=$(task_project "$file" "$id")
            case $BY in
                project) key=$proj; lbl=$proj ;;
                task)    key="$d/$id"; lbl="$id  $(task_desc "$file" "$id")" ;;
            esac
            m=$(task_minutes "$file" "$id" "$nm")
            (( m > 0 )) || continue
            [[ -n ${LABEL[$key]:-} ]] || { rows+=("$key"); LABEL[$key]=$lbl; PROJ[$key]=$proj; }
            AGG[$key/$d]=$(( ${AGG[$key/$d]:-0} + m ))
            RTOTAL[$key]=$(( ${RTOTAL[$key]:-0} + m ))
        done < <(task_ids "$file")
    done

    if (( JSON )); then
        printf '{"from":%s,"to":%s,"by":%s,"days":[' "$(json_str "$from")" "$(json_str "$to")" "$(json_str "$BY")"
        local first=1
        for d in "${days[@]}"; do (( first )) && first=0 || printf ','; printf '%s' "$(json_str "$d")"; done
        printf '],"rows":['
        first=1
        for key in "${rows[@]}"; do
            (( first )) && first=0 || printf ','
            printf '{"key":%s,"label":%s,"project":%s,"total_minutes":%d,"perDay":{' \
                "$(json_str "$key")" "$(json_str "${LABEL[$key]}")" \
                "$(json_str "${PROJ[$key]}")" "${RTOTAL[$key]}"
            local pfirst=1
            for d in "${days[@]}"; do
                [[ -n ${AGG[$key/$d]:-} ]] || continue
                (( pfirst )) && pfirst=0 || printf ','
                printf '%s:%d' "$(json_str "$d")" "${AGG[$key/$d]}"
            done
            printf '}}'
        done
        printf ']}\n'
        return
    fi

    # text rendering: rows x days matrix of durations
    printf '\nGantt %s..%s  by %s\n\n' "$from" "$to" "$BY"
    printf '%-20s' ''
    for d in "${days[@]}"; do printf ' %7s' "${d:5}"; done
    printf ' %8s\n' TOTAL
    for key in "${rows[@]}"; do
        printf '%-20.20s' "${LABEL[$key]}"
        for d in "${days[@]}"; do
            if [[ -n ${AGG[$key/$d]:-} ]]; then printf ' %7s' "$(fmt_dur "${AGG[$key/$d]}")"; else printf ' %7s' '·'; fi
        done
        printf ' %8s\n' "$(fmt_dur "${RTOTAL[$key]}")"
    done
    printf '\n'
}

# ---------------------------------------------------------------------------
# Pending backlog — not-yet-started tasks, kept in a separate mutable file and
# invisible to the time views until promoted via `wj start P#`.
# ---------------------------------------------------------------------------

# highest existing P# in the backlog (0 if none)
pending_max_id() {
    local f id rest n max=0
    f=$(pending_file)
    [[ -f $f ]] || { echo 0; return; }
    while IFS=$'\t' read -r id rest || [[ -n $id ]]; do
        n=${id#P}
        [[ $n =~ ^[0-9]+$ ]] && (( n > max )) && max=$n
    done <"$f"
    echo "$max"
}

# look up a pending entry, setting PEND_PROJ / PEND_DESC; return 1 if absent
PEND_PROJ=""; PEND_DESC=""
pending_get() {
    local want=$1 f line
    f=$(pending_file); [[ -f $f ]] || return 1
    while IFS= read -r line || [[ -n $line ]]; do
        tsv_split "$line"
        [[ ${PF[0]:-} == "$want" ]] && { PEND_PROJ=${PF[2]:-}; PEND_DESC=${PF[4]:-}; return 0; }
    done <"$f"
    return 1
}

# remove the entry with id $1; return 1 if not found
pending_remove() {
    local want=$1 f tmp found=1 line id
    f=$(pending_file); [[ -f $f ]] || return 1
    tmp=$(mktemp "$f.XXXXXX") # same dir as $f so the mv is an atomic rename
    while IFS= read -r line || [[ -n $line ]]; do
        id=${line%%$'\t'*}
        [[ $id == "$want" ]] && { found=0; continue; }
        printf '%s\n' "$line" >>"$tmp"
    done <"$f"
    mv "$tmp" "$f"
    return $found
}

# set (or clear, when $2 is empty) the due date of entry $1; return 1 if absent
pending_set_due() {
    local want=$1 newdue=$2 f tmp found=1 line
    f=$(pending_file); [[ -f $f ]] || return 1
    tmp=$(mktemp "$f.XXXXXX")
    while IFS= read -r line || [[ -n $line ]]; do
        tsv_split "$line"
        [[ ${PF[0]:-} == "$want" ]] && { PF[3]=$newdue; found=0; }
        printf '%s\t%s\t%s\t%s\t%s\n' "${PF[0]:-}" "${PF[1]:-}" "${PF[2]:-}" "${PF[3]:-}" "${PF[4]:-}" >>"$tmp"
    done <"$f"
    mv "$tmp" "$f"
    return $found
}

# swap entry $1 with its neighbour ($2 = up|down); edge moves are a no-op
pending_move() {
    local want=$1 dir=$2 f line i idx=-1 n j tmp out
    f=$(pending_file); [[ -f $f ]] || return 1
    local -a lines=()
    while IFS= read -r line || [[ -n $line ]]; do lines+=("$line"); done <"$f"
    n=${#lines[@]}
    for (( i=0; i<n; i++ )); do
        [[ ${lines[i]%%$'\t'*} == "$want" ]] && { idx=$i; break; }
    done
    (( idx < 0 )) && return 1
    if [[ $dir == up ]]; then j=$(( idx - 1 )); else j=$(( idx + 1 )); fi
    (( j < 0 || j >= n )) && return 0 # already at the edge
    tmp=${lines[idx]}; lines[idx]=${lines[j]}; lines[j]=$tmp
    out=$(mktemp "$f.XXXXXX")
    for (( i=0; i<n; i++ )); do printf '%s\n' "${lines[i]}" >>"$out"; done
    mv "$out" "$f"
}

cmd_add() {
    local desc proj
    desc=$(sanitize "${ARGS[*]:-}"); proj=$PROJECT_OVERRIDE   # already normalized in parse_args
    [[ -n $desc ]] || die "add needs a description (e.g. wj add \"Fix invoice\")"
    [[ -z $DUE ]] || valid_date "$DUE" || die "--due must be a real date YYYY-MM-DD (got '$DUE')"
    local f id created
    f=$(pending_file); mkdir -p "$(dirname "$f")"
    id="P$(( $(pending_max_id) + 1 ))"
    created=$(date +%Y-%m-%dT%H:%M)
    printf '%s\t%s\t%s\t%s\t%s\n' "$id" "$created" "$proj" "$DUE" "$desc" >>"$f"
    printf '%s  added%s%s — %s\n' "$id" "${proj:+ [$proj]}" "${DUE:+ (due $DUE)}" "$desc"
}

cmd_pending() {
    local f line id created proj due desc first=1 found=0
    f=$(pending_file)
    if (( JSON )); then
        printf '['
        if [[ -f $f ]]; then
            while IFS= read -r line || [[ -n $line ]]; do
                tsv_split "$line"; id=${PF[0]:-}
                [[ -n $id ]] || continue
                (( first )) && first=0 || printf ','
                printf '{"id":%s,"created":%s,"project":%s,"due":%s,"desc":%s}' \
                    "$(json_str "$id")" "$(json_str "${PF[1]:-}")" "$(json_str "${PF[2]:-}")" \
                    "$(json_str "${PF[3]:-}")" "$(json_str "${PF[4]:-}")"
            done <"$f"
        fi
        printf ']\n'
        return
    fi
    printf '\nPending\n\n'
    if [[ -f $f ]]; then
        while IFS= read -r line || [[ -n $line ]]; do
            tsv_split "$line"; id=${PF[0]:-}
            [[ -n $id ]] || continue
            found=1; proj=${PF[2]:-}; due=${PF[3]:-}; desc=${PF[4]:-}
            printf '%-4s  %-16.16s  %-10s  %s\n' "$id" "${proj:-—}" "${due:-—}" "$desc"
        done <"$f"
    fi
    (( found )) || printf '  (empty)\n'
    printf '\n'
}

cmd_drop() {
    local id=${ARGS[0]:-}
    [[ $id =~ ^P[0-9]+$ ]] || die "drop needs a pending id (e.g. wj drop P2)"
    pending_remove "$id" || die "no such pending task: $id"
    printf '%s  dropped\n' "$id"
}

cmd_due() {
    local id=${ARGS[0]:-} val=${ARGS[1]:-}
    [[ $id =~ ^P[0-9]+$ ]] || die "due needs a pending id (e.g. wj due P2 2026-06-10)"
    [[ -n $val ]] || die "due needs a date (YYYY-MM-DD) or - to clear"
    [[ $val == - ]] && val=""
    [[ -z $val ]] || valid_date "$val" || die "due date must be a real date YYYY-MM-DD or - (got '$val')"
    pending_set_due "$id" "$val" || die "no such pending task: $id"
    printf '%s  due %s\n' "$id" "${val:-cleared}"
}

cmd_raise() {
    local id=${ARGS[0]:-}
    [[ $id =~ ^P[0-9]+$ ]] || die "raise needs a pending id (e.g. wj raise P2)"
    pending_move "$id" up || die "no such pending task: $id"
}

cmd_lower() {
    local id=${ARGS[0]:-}
    [[ $id =~ ^P[0-9]+$ ]] || die "lower needs a pending id (e.g. wj lower P2)"
    pending_move "$id" down || die "no such pending task: $id"
}

# search every recorded task (all-time) by a case-insensitive substring,
# matched against the task id, project, and current description. Most-recent
# day first. --json emits the array the wj-tui search overlay consumes.
cmd_search() {
    local q=${ARGS[0]:-}
    local ql=${q,,}

    if (( JSON )); then printf '['; else printf '\nSearch %s\n\n' "${q:-(all)}"; fi
    local first=1 found=0

    if [[ -d $WJ_DATA_DIR ]]; then
        local file base dd mm yyyy d id proj desc st mins nm hay
        while IFS= read -r file; do
            base=${file%.tsv}
            dd=${base##*/};   base=${base%/*}
            mm=${base##*/};   base=${base%/*}
            yyyy=${base##*/}
            [[ $yyyy =~ ^[0-9]{4}$ && $mm =~ ^[0-9]{2}$ && $dd =~ ^[0-9]{2}$ ]] || continue
            d="$yyyy-$mm-$dd"
            nm=$(report_nm "$d" "$file")
            while read -r id; do
                [[ -z $id ]] && continue
                task_cancelled "$file" "$id" && continue
                proj=$(task_project "$file" "$id")
                desc=$(task_desc "$file" "$id")
                hay="$id $proj $desc"
                [[ -z $ql || ${hay,,} == *"$ql"* ]] || continue
                st=$(task_status "$file" "$id")
                mins=$(task_minutes "$file" "$id" "$nm")
                found=1
                if (( JSON )); then
                    (( first )) && first=0 || printf ','
                    printf '{"id":%s,"date":%s,"project":%s,"desc":%s,"status":%s,"minutes":%d}' \
                        "$(json_str "$id")" "$(json_str "$d")" "$(json_str "$proj")" \
                        "$(json_str "$desc")" "$(json_str "$st")" "$mins"
                else
                    printf '%-12s  %-4s  %-16.16s  %-8s  %7s  %s\n' \
                        "$d" "$id" "$proj" "$st" "$(fmt_dur "$mins")" "$desc"
                fi
            done < <(task_ids "$file")
        done < <(find "$WJ_DATA_DIR" -name '*.tsv' -type f 2>/dev/null | sort -r)
    fi

    if (( JSON )); then printf ']\n'; else (( found )) || printf '  (no matches)\n'; printf '\n'; fi
}

cmd_export() {
    local from=${FROM:-$TODAY} to=${TO:-$TODAY} d file
    case $FORMAT in
        csv)  printf 'timestamp,task_id,project,event,note\n' ;;
        tsv)  printf 'timestamp\ttask_id\tproject\tevent\tnote\n' ;;
        json) printf '[' ;;
        *)    die "--format must be csv|json|tsv" ;;
    esac
    local first=1 ts id proj evt note
    while read -r d; do
        file=$(day_file "$d")
        [[ -f $file ]] || continue
        while IFS=$'\t' read -r ts id proj evt note; do
            case $FORMAT in
                tsv)  printf '%s\t%s\t%s\t%s\t%s\n' "$ts" "$id" "$proj" "$evt" "$note" ;;
                csv)  printf '%s,%s,%s,%s,%s\n' \
                        "$(csv_escape "$ts")" "$(csv_escape "$id")" "$(csv_escape "$proj")" \
                        "$(csv_escape "$evt")" "$(csv_escape "$note")" ;;
                json)
                    (( first )) && printf '\n' || printf ',\n'; first=0
                    printf '  {"timestamp":%s,"task_id":%s,"project":%s,"event":%s,"note":%s}' \
                        "$(json_str "$ts")" "$(json_str "$id")" "$(json_str "$proj")" \
                        "$(json_str "$evt")" "$(json_str "$note")" ;;
            esac
        done <"$file"
    done < <(iter_dates "$from" "$to")
    # `if`, not `&&`: as the last statement, `[[..]] && {..}` would return 1
    # for csv/tsv (non-json), making a successful export exit non-zero.
    if [[ $FORMAT == json ]]; then (( first )) && printf ']\n' || printf '\n]\n'; fi
}

# internal: today's task ids (for shell completion)
list_task_ids() { task_ids "$(day_file "$TODAY")"; }
# internal: pending P# ids (for shell completion)
list_pending_ids() { local f; f=$(pending_file); [[ -f $f ]] && awk -F'\t' '{print $1}' "$f"; }
# internal: distinct project names ever seen (for shell completion)
list_projects() {
    [[ -d $WJ_DATA_DIR ]] || return 0
    find "$WJ_DATA_DIR" -name '*.tsv' -type f -exec awk -F'\t' '{print $3}' {} + 2>/dev/null \
        | sort -u | grep -v '^$'
}

cmd_completion() {
    local shell=${ARGS[0]:-bash}
    case $shell in bash|zsh) ;; *) die "completion supports: bash | zsh" ;; esac
    [[ $shell == zsh ]] && printf 'autoload -U +X bashcompinit && bashcompinit\n'
    cat <<'EOF'
_wj() {
    local cur prev cmds flags cmd
    cur=${COMP_WORDS[COMP_CWORD]}
    prev=${COMP_WORDS[COMP_CWORD-1]}
    cmds="start continue pause resume complete defer log amend move cancel ls show status grid gantt search add pending drop due raise lower report export ui config completion version help"
    flags="--at --date --project --from --to --format --by --days --due --json --parallel --auto-pause"
    if (( COMP_CWORD == 1 )); then
        COMPREPLY=( $(compgen -W "$cmds" -- "$cur") ); return
    fi
    case $prev in
        --format)    COMPREPLY=( $(compgen -W "csv json tsv" -- "$cur") ); return ;;
        --by)        COMPREPLY=( $(compgen -W "project task day" -- "$cur") ); return ;;
        --project)   COMPREPLY=( $(compgen -W "$(wj _projects 2>/dev/null)" -- "$cur") ); return ;;
        completion)  COMPREPLY=( $(compgen -W "bash zsh" -- "$cur") ); return ;;
    esac
    if [[ $cur == -* ]]; then COMPREPLY=( $(compgen -W "$flags" -- "$cur") ); return; fi
    cmd=${COMP_WORDS[1]}
    case $cmd in
        continue|pause|resume|complete|defer|amend|move|cancel|show)
            COMPREPLY=( $(compgen -W "$(wj _tasks 2>/dev/null)" -- "$cur") ) ;;
        drop|due|raise|lower)
            COMPREPLY=( $(compgen -W "$(wj _pending 2>/dev/null)" -- "$cur") ) ;;
        start)
            COMPREPLY=( $(compgen -W "$(wj _pending 2>/dev/null)" -- "$cur") ) ;;
    esac
}
complete -F _wj wj
EOF
}

cmd_help() {
    cat <<'EOF'
wj — cross-project daily task & time tracker

Track what you work on across every project from one CLI. Each action appends to
an immutable per-day TSV event log; status, grids, reports and exports are all
derived from that log, so your data stays plain, greppable and easy to analyse.

USAGE
  wj [command] [args] [flags]

  Project is auto-detected (git remote -> repo folder -> default_project).
  Run with no command to show today's status.

TASK COMMANDS
  start <desc|P#>     Begin a new task. Gets the next id (T1, T2, ... per day).
                      Runs alongside any task already going in the SAME project
                      (use --auto-pause, or auto_pause=on, to pause it first).
                      Given a pending id (P#) it promotes that backlog item instead.
  continue <id>       Pick up a past day's task today: copies its description and
                      --date YYYY-MM-DD  project into a fresh task for today (new id, own clock) and
                      notes the lineage. --date (the source day) is required;
                      --at sets the start time, --project overrides the project.
  pause  [id] [why]   Pause the running task (or the given id). Stops its clock.
  resume [id]         Resume the most-recent paused/deferred task (or given id).
                      Runs in parallel by default; --auto-pause pauses the
                      project's other running task first.
  complete [id]       Finish a task and sum its tracked time.
  defer  [id] [why]   Set a task aside (e.g. blocked / picking it up another day).
  log <note>          Attach a timestamped note to the running task.
  amend [id] <desc>   Replace a task's description (running task, or given id).
                      Keeps history: appends an event, never rewrites the log.
  move  [id] <proj>   Re-home a task to another project (fix wrong auto-detection).
  cancel [id]         Void a mistaken task: 0 time, hidden from status/grid/report
                      (kept in the raw log / export for audit).

PENDING (BACKLOG)
  add <desc>          Add a not-yet-started task to the backlog (id P1, P2, ...).
                      --project X sets its project; --due YYYY-MM-DD a deadline.
                      Pending tasks stay out of the time views until promoted.
  pending             List the backlog in manual (pinned) order.
  due <P#> <date|->   Set or clear (-) a pending task's deadline.
  raise <P#>          Move a pending task one step up (lower = one step down).
  lower <P#>          Move a pending task one step down.
  drop <P#>           Remove a pending task without starting it.
                      (Use `start P#` to promote one into a tracked task.)

VIEW & ANALYSIS
  ls                  List currently-open tasks (in-progress / paused / deferred).
                      Today by default; --days N scans the last N days (adds a DATE
                      column) to catch timers you left running on an earlier day.
  show <id>           Full timeline of one task: start, notes, pauses/resumes,
                      renames, moves, total time and status.
                      Today by default; --date YYYY-MM-DD for a past day.
  status [date]       Per-task totals table for a day (default: today). Default cmd.
  grid   [date]       Slot-by-slot schedule for a day (see SYMBOLS below).
  gantt  [flags]      Multi-day overview: rows (--by project|task) x days of time.
                      Default range: last 7 days through --to. The headline UI view.
                      --by task lists each day's tasks separately (ids are per-day).
  search <query>      Find tasks (all-time) by id / project / description substring.
                      Scans every recorded day; most-recent first. --json for the UI.
  report [flags]      Aggregate time across a date range, grouped by --by.
  export [flags]      Dump raw events as csv / json / tsv over a date range.

  Read views (status, show, grid, gantt, search, pending) also accept --json for a
  stable machine-readable contract — this is what the `ui` front-end consumes.

OTHER
  ui                  Launch the wj-tui front-end (requires the wj-tui binary).
                      Bare `wj` launches it too when interface=ui in the config.
  config              Print the path to the active config file.
  completion SHELL    Print a completion script: completion bash | completion zsh.
  version             Print the wj version (also: --version, -V).
  help                Show this help.

FLAGS
  --at TIME           Act at a past time instead of now. Flexible format: 9, 930,
                      0930, 9:30, 9.30, 9am, 9pm, 9:30pm all normalise to HH:MM.
                      Backfills the grid; chain across commands to rebuild a day.
  --date YYYY-MM-DD   Act on another day, not today (alias: --on). Combine with --at
                      to reconstruct any past day; defaults the day for status/grid.
                      On a past day WITHOUT --at, the time is inferred from that day's
                      last event (or shift_start), and the inference is printed.
  --days N            ls: how many days back to scan for open tasks. Default: 1 (today).
  --project NAME      Override project detection. Use for non-git work, e.g.
                      --project meetings / --project "maroc ventes" / --project admin.
                      On start: where the task lives. On pause/complete/etc: scope.
  --from D --to D     Inclusive date range YYYY-MM-DD (report, export, gantt).
  --by KEY            row grouping: project | task | day (report); project | task
                      (gantt). Default: project.
  --due YYYY-MM-DD    add: optional deadline for a pending task.
  --format FMT        export format: csv | json | tsv. Default: csv.
  --parallel          start/resume: leave any other running task in the same
                      project running, so you track several in parallel.
  --auto-pause        start/resume: auto-pause the project's other running task
                      first (one in-progress task per project). These two flags
                      override the auto_pause config for a single command.

STATUSES & GRID SYMBOLS
  in-progress  >>     paused  --     completed  **     deferred  ~~     (idle blank)
  cancelled tasks are voided and omitted from views (still in the raw log).

CONCURRENCY
  By default tasks run in parallel: starting or resuming a task leaves any other
  running task untouched (auto_pause=off). Set auto_pause=on, or pass --auto-pause,
  to keep one in-progress task per project (start/resume auto-pauses the previous
  one); --parallel forces the opposite for a single command. Different projects
  always run at once — each is its own grid column.

IDEMPOTENT STATE CHANGES
  Repeating an action whose state the task already holds does nothing: pause on
  a paused task (likewise resume on a running one, complete on a completed one,
  defer and cancel) appends no event and just prints e.g. "T1  already paused".

CONFIG  (~/.config/wj/cfg — INI [sections], created on first run)
  shift_start / shift_end   default grid frame; comment out to auto-fit (09:00 / 19:00)
  slot_minutes              grid time-step, i.e. the "jump"           (5)
  round                     grid snapping: down | nearest             (down)
  totals                    time summing: exact | slot               (exact)
  default_project           project used outside a git repo          (admin)
  interface                 bare-wj front-end: minimal | ui          (minimal)
  auto_pause                start/resume auto-pause same project     (off)
  accent                    wj-tui focused-panel border color        (141)
  layout                    wj-tui panels: balanced|spotlight|golden (balanced)
  sidebar                   wj-tui sidebar side: left | right        (left)
  layout_sidebar            custom layout sidebar width %, e.g. 28    ()
  layout_split              custom layout weights focused,hi,lo      ()
  color_projects            per-panel title colors in wj-tui — one   (39)
  color_tasks               per panel; same value formats as accent  (214)
  color_pending             (a 256-color code, #hex, or ANSI name)   (170)
  color_range                                                        (78)
  color_day                                                          (45)
  color_timeline                                                     (180)

EXAMPLES
  wj start "Refactor auth" --project backend   # start tracking
  wj log "extracted token service"             # note on the running task
  wj amend "Refactor auth + token service"     # fix the running task's name
  wj amend T2 "Standup & planning"             # ...or a specific task by id
  wj move T1 frontend                          # re-home a mis-detected task
  wj cancel T3                                  # void a task started by mistake
  wj pause                                      # pause it (heading into a meeting)
  wj start "Standup" --project meetings         # a different, non-git project
  wj complete --project meetings                # finish standup
  wj resume                                     # back to the refactor (most-recent paused)
  wj start "Code review" --auto-pause           # pause the refactor first, one at a time
  wj start "Quick fix"                          # default: runs alongside the refactor
  wj complete                                   # finish it; time summed
  wj ls                                         # what's open right now
  wj ls --days 7                                # anything left open this past week
  wj show T1                                     # full timeline of one task
  wj status                                     # today's totals
  wj grid                                       # today's schedule
  wj report --from 2026-06-01 --to 2026-06-30 --by project
  wj export --format csv > june.csv

  # Reconstruct a past morning retroactively (any day, with --date):
  wj start "Fixing auth" --date 2026-05-30 --at 09:00 --project backend
  wj pause T1 --date 2026-05-30 --at 09:30
  wj complete T1 --date 2026-05-30 --at 11:30
  wj status --date 2026-05-30                   # review that day

  # One-time setup: shell completion
  echo 'eval "$(wj completion bash)"' >> ~/.bashrc   # or: completion zsh -> ~/.zshrc

FILES
  config :  ~/.config/wj/cfg             (override: $WJ_CONFIG)
  data   :  ~/.local/share/wj/YYYY/MM/DD.tsv   (override: $WJ_DATA_DIR)
EOF
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
main() {
    load_config
    # version is checked before the default-view logic so `wj --version` works
    if [[ ${1:-} == version || ${1:-} == --version || ${1:-} == -V ]]; then
        printf 'wj %s\n' "$WJ_VERSION"; return 0
    fi
    local cmd
    # no command, or a leading flag (e.g. `wj --json`), means "default view"
    if [[ $# -eq 0 || $1 == -* ]]; then cmd=__default; else cmd=$1; shift; fi
    parse_args "$@"
    # mutating commands take a process-wide lock so concurrent invocations can't
    # interleave their read-derive-append sequences (see acquire_lock).
    case $cmd in
        start|continue|pause|resume|complete|defer|log|amend|move|cancel|add|drop|due|raise|lower)
            acquire_lock ;;
    esac
    case $cmd in
        __default)
            # bare `wj`: launch the UI front-end when configured & available,
            # otherwise fall back to today's status (the classic default).
            if [[ $interface == ui ]] && command -v wj-tui >/dev/null 2>&1; then
                local -a uiargs=(-wj "$(self_path)")
                [[ -n ${accent:-} ]] && uiargs+=(-accent "$accent")
                [[ -n ${layout:-} ]] && uiargs+=(-layout "$layout")
                [[ -n ${sidebar:-} ]] && uiargs+=(-sidebar "$sidebar")
                [[ -n ${layout_sidebar:-} ]] && uiargs+=(-layout-sidebar "$layout_sidebar")
                [[ -n ${layout_split:-} ]] && uiargs+=(-layout-split "$layout_split")
                local cspec; cspec=$(ui_colorspec)
                [[ -n $cspec ]] && uiargs+=(-colors "$cspec")
                exec wj-tui "${uiargs[@]}"
            fi
            cmd_status ;;
        ui)
            command -v wj-tui >/dev/null 2>&1 \
                || die "ui mode needs the 'wj-tui' binary (not installed) — see README"
            # tell wj-tui to call *this* wj (not whatever is first on PATH), and
            # translate the parsed range/grouping globals into its flags
            local -a uiargs=(-wj "$(self_path)")
            [[ -n $FROM ]] && uiargs+=(-from "$FROM")
            [[ -n $TO ]]   && uiargs+=(-to "$TO")
            [[ -n $BY ]]   && uiargs+=(-by "$BY")
            [[ -n ${accent:-} ]] && uiargs+=(-accent "$accent")
            [[ -n ${layout:-} ]] && uiargs+=(-layout "$layout")
            [[ -n ${sidebar:-} ]] && uiargs+=(-sidebar "$sidebar")
            [[ -n ${layout_sidebar:-} ]] && uiargs+=(-layout-sidebar "$layout_sidebar")
            [[ -n ${layout_split:-} ]] && uiargs+=(-layout-split "$layout_split")
            local cspec; cspec=$(ui_colorspec)
            [[ -n $cspec ]] && uiargs+=(-colors "$cspec")
            exec wj-tui "${uiargs[@]}" ;;
        gantt)    cmd_gantt ;;
        start)    cmd_start ;;
        continue) cmd_continue ;;
        pause)    cmd_pause ;;
        resume)   cmd_resume ;;
        complete) cmd_complete ;;
        defer)    cmd_defer ;;
        log)      cmd_log ;;
        amend)    cmd_amend ;;
        move)     cmd_move ;;
        cancel)   cmd_cancel ;;
        ls)       cmd_ls ;;
        show)     cmd_show ;;
        status)   cmd_status ;;
        grid)     cmd_grid ;;
        search)   cmd_search ;;
        add)      cmd_add ;;
        pending)  cmd_pending ;;
        drop)     cmd_drop ;;
        due)      cmd_due ;;
        raise)    cmd_raise ;;
        lower)    cmd_lower ;;
        report)   cmd_report ;;
        export)   cmd_export ;;
        completion) cmd_completion ;;
        config|cfg) printf '%s\n' "$WJ_CONFIG" ;;
        _tasks)   list_task_ids ;;
        _pending) list_pending_ids ;;
        _projects) list_projects ;;
        help|-h|--help) cmd_help ;;
        *)        die "unknown command: $cmd (try 'wj help')" ;;
    esac
}

# Only auto-run when executed directly. When sourced (e.g. by the bats test
# suite to unit-test the helper functions) this is skipped, so sourcing defines
# the functions without dispatching a command.
if [[ ${BASH_SOURCE[0]} == "${0}" ]]; then
    main "$@"
fi
